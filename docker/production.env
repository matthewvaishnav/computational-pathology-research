# Production environment variables for HistoCore streaming

# ============================================================================
# Application Settings
# ============================================================================
HISTOCORE_ENV=production
HISTOCORE_LOG_LEVEL=INFO
HISTOCORE_DEBUG=false

# ============================================================================
# GPU and Memory
# ============================================================================
CUDA_VISIBLE_DEVICES=0
HISTOCORE_MAX_MEMORY_GB=8
HISTOCORE_BATCH_SIZE=32
HISTOCORE_MAX_PATCHES_PER_SLIDE=10000

# ============================================================================
# Performance
# ============================================================================
HISTOCORE_WORKERS=4
HISTOCORE_TIMEOUT=300
HISTOCORE_KEEP_ALIVE=2
HISTOCORE_MAX_REQUESTS=1000

# ============================================================================
# Cache and Storage
# ============================================================================
REDIS_URL=redis://redis:6379
HISTOCORE_CACHE_TTL=3600
HISTOCORE_CACHE_MAX_SIZE=1000

# ============================================================================
# Monitoring
# ============================================================================
PROMETHEUS_PORT=8002
HISTOCORE_METRICS_ENABLED=true
HISTOCORE_HEALTH_CHECK_INTERVAL=30

# ============================================================================
# Security
# ============================================================================
HISTOCORE_SECRET_KEY=change-this-in-production
HISTOCORE_CORS_ORIGINS=*
HISTOCORE_RATE_LIMIT=100/minute

# ============================================================================
# Clinical Integration
# ============================================================================
HISTOCORE_PACS_ENABLED=true
HISTOCORE_FHIR_ENABLED=true
HISTOCORE_EMR_ENABLED=false

# ============================================================================
# Paths
# ============================================================================
HISTOCORE_DATA_PATH=/app/data
HISTOCORE_LOG_PATH=/app/logs
HISTOCORE_CACHE_PATH=/app/cache
HISTOCORE_MODEL_PATH=/app/checkpoints