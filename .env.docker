# Medical AI Platform - Docker Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://medai:medai123@postgres:5432/medical_ai
POSTGRES_DB=medical_ai
POSTGRES_USER=medai
POSTGRES_PASSWORD=medai123

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=/app/checkpoints/pcam_real/best_model.pth
MODEL_VERSION=1.0.0
CONFIDENCE_THRESHOLD=0.8

# Security Configuration
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=/app/data/uploads
SUPPORTED_FORMATS=svs,ndpi,tiff,dcm

# Monitoring Configuration
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
ENABLE_METRICS=true

# DICOM Configuration
DICOM_AE_TITLE=MEDICAL_AI
DICOM_PORT=11112

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@medical-ai.com

# External Services
OPENAI_API_KEY=your-openai-key
HUGGINGFACE_TOKEN=your-hf-token

# Development/Debug
DEBUG=false
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080