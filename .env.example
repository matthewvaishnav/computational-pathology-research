# ============================================================================
# Medical AI Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development  # Options: development, staging, production

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Secret Key (REQUIRED - generate a strong random key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY

# Encryption Password for Model Storage (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_PASSWORD=CHANGE_THIS_TO_A_SECURE_RANDOM_PASSWORD

# Model Encryption Key File Path (optional, defaults to /secure/keys/model.key)
MODEL_KEY_FILE=/secure/keys/model.key

# ============================================================================
# CORS Configuration
# ============================================================================

# Allowed Origins (comma-separated list of allowed domains)
# Development example:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Production example:
# ALLOWED_ORIGINS=https://app.hospital.com,https://admin.hospital.com

# ============================================================================
# Database Configuration
# ============================================================================

# Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/medical_ai

# Database Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================================================
# Monitoring and Tracing
# ============================================================================

# Jaeger Tracing Endpoint (optional)
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# OpenTelemetry Endpoint (optional)
OTLP_ENDPOINT=http://localhost:4317

# ============================================================================
# File Upload Configuration
# ============================================================================

# Maximum file upload size in bytes (default: 100MB)
MAX_FILE_SIZE=104857600

# Temporary file storage directory
TEMP_UPLOAD_DIR=/tmp/medical_ai_uploads

# ============================================================================
# Rate Limiting Configuration
# ============================================================================

# Login rate limit (attempts per minute)
LOGIN_RATE_LIMIT=5

# Account lockout threshold (failed attempts before lockout)
LOCKOUT_THRESHOLD=5

# Account lockout duration (seconds)
LOCKOUT_DURATION=900

# ============================================================================
# Model Configuration
# ============================================================================

# Model storage path
MODEL_STORAGE_PATH=/models

# Model cache size (number of models to keep in memory)
MODEL_CACHE_SIZE=3

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (optional)
LOG_FILE=/var/log/medical_ai/api.log

# ============================================================================
# HTTPS Configuration (Production)
# ============================================================================

# SSL Certificate Path (production only)
SSL_CERT_PATH=/etc/ssl/certs/medical_ai.crt

# SSL Key Path (production only)
SSL_KEY_PATH=/etc/ssl/private/medical_ai.key

# ============================================================================
# External Services
# ============================================================================

# PACS Integration (optional)
PACS_AE_TITLE=HISTOCORE
PACS_HOST=pacs.hospital.com
PACS_PORT=11112

# Email Service (for notifications)
SMTP_HOST=smtp.hospital.com
SMTP_PORT=587
SMTP_USER=notifications@hospital.com
SMTP_PASSWORD=CHANGE_THIS

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable features
ENABLE_AUDIT_LOGGING=true
ENABLE_MALWARE_SCANNING=false  # Set to true when ClamAV is configured
ENABLE_HTTPS_REDIRECT=false  # Set to true in production

# ============================================================================
# Compliance Configuration
# ============================================================================

# HIPAA Compliance Mode
HIPAA_COMPLIANCE_MODE=true

# Data retention period (days)
DATA_RETENTION_DAYS=2555  # 7 years for HIPAA

# Audit log retention period (days)
AUDIT_LOG_RETENTION_DAYS=2555

# ============================================================================
# Performance Configuration
# ============================================================================

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Worker processes (for production deployment)
WORKERS=4

# Worker connections
WORKER_CONNECTIONS=1000
